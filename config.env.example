# Copy to config.env and edit paths/allocation as needed.
# Or run ./setup.sh to generate config.env automatically.

ROOT=/path/to/carbon_2.0_cpu_gpu_benchmark
CARBON_SETUP=/path/to/carbon_2.0_simulation_setup
CHIMES_REPO=/path/to/carbon_2.0_cpu_gpu_benchmark/vendor/chimes_calculator

LMP_CPU=${CHIMES_REPO}/etc/lmp/exe/lmp_mpi_chimes
LMP_GPU=${CHIMES_REPO}/etc/lmp/exe/lmp_mpi_chimes_gpu
PARAM_FILE=${CARBON_SETUP}/force_fields/published_params.Carbon-2.0.Small.2+3+4b.Tersoff.txt

TOLERANCE=1e-3
SLURM_ALLOC=TG-CHM250118
SLURM_PARTITION=rtx-small

STATEPOINTS="1500K_graph 2000K_1.0gcc 3000K_diam 6000K_3.6gcc 8000K_3.0gcc"
